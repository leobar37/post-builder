    "remotion": "remotion studio src/remotion/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/player": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "axios": "^1.13.2",
    "better-sqlite3": "^9.6.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "execa": "^8.0.0",
    "express": "^4.18.0",
    "ffmpeg-static": "^5.3.0",
    "nanoid": "^5.0.0",
    "ora": "^8.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "remotion": "^4.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
